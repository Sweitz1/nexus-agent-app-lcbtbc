# Database
DATABASE_URL="postgresql://user:password@host:5432/nexus_unlock"

# JWT — generate with: openssl rand -base64 32
JWT_SECRET="your-secret-here"
JWT_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_ENTERPRISE="price_..."

# Unlock Provider — set DEMO_MODE=true to simulate (no API key needed)
DEMO_MODE="true"
UNLOCK_PROVIDER_API_URL=""
UNLOCK_PROVIDER_API_KEY=""

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Nexus Unlock <noreply@nexusunlock.com>"

# Server
PORT="4000"
FRONTEND_URL="http://localhost:3000"
