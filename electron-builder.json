  "main": "electron-main.js",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "electron-main.js",
    "assets/icon.png",
    "assets/icon.ico"
  ],
  "win": {
    "target": [
      {
        "target": "msi",
