# Database (PostgreSQL — use Neon, Railway, Supabase, or local)
DATABASE_URL="postgresql://user:password@host:5432/nexus_unlock"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_STARTER="price_..."      # $99/mo - 100 credits
STRIPE_PRICE_PRO="price_..."          # $249/mo - 300 credits
STRIPE_PRICE_ENTERPRISE="price_..."   # $499/mo - unlimited

# Unlock Provider API (add when you sign up with a wholesale provider)
# Recommended: DirectUnlocks (directunlocks.com/reseller) or UnlockBase
UNLOCK_PROVIDER_API_URL="https://api.yourprovider.com"
UNLOCK_PROVIDER_API_KEY=""

# Demo mode: set to "true" to use simulated unlocks (no real API needed for testing)
DEMO_MODE="true"

# Email (optional - for order notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Nexus Unlock <noreply@yourdomain.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Nexus Unlock"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
